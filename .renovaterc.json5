{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:best-practices",
    "docker:enableMajor",
    "github>home-operations/renovate-presets#1.1.0",
    "github>alexwaibel/home-ops//.renovate/autoMerge.json5",
    "github>alexwaibel/home-ops//.renovate/groups.json5",
    "github>alexwaibel/home-ops//.renovate/labels.json5",
    ":automergeBranch",
    ":disableRateLimiting",
    ":semanticCommits",
    ':timezone(America/Los_Angeles)',
  ],
  packageRules: [
    {
      description: "Disable digest pinning for helmfile manager (format has no digest field)",
      matchManagers: [
        "helmfile"
      ],
      pinDigests: false,
    },
    {
      description: "Disable digest pinning for flux manager (tag@sha256 breaks flux-local helm template)",
      matchManagers: [
        "flux"
      ],
      pinDigests: false,
    },
    {
      description: "Disable digest pinning for talenv.yaml, talhelper doesn't support digests",
      matchFileNames: [
        "talos/talenv.yaml"
      ],
      pinDigests: false,
    },
  ],
}